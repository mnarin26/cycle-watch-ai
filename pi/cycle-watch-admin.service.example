# Örnek: Ethernet'e özgü yönetici paneli (varsayılan 192.168.50.1:5274)
# Kurulum: sudo cp cycle-watch-admin.service.example /etc/systemd/system/cycle-watch-admin.service
#          sudo systemctl daemon-reload && sudo systemctl enable --now cycle-watch-admin

[Unit]
Description=Cycle Watch — yönetici paneli (yalnızca Ethernet bind)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/cycle-watch-ai
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NODE_ENV=development
# eth0 statik IP ile aynı adresi kullanın; port ana arayüzden (5173) ayrı
Environment=ADMIN_BIND_ADDRESS=0.0.0.0
Environment=ADMIN_PORT=5274
Environment=CW_AP_SSID=pi-wifi
Environment=CW_AP_PASSWORD=123456789
Environment=CW_ANALYSIS_PORT=5173
ExecStart=/usr/local/bin/npm run dev:admin
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
